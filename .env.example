# ============================================================
# FOOD CLUB — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub.
# ============================================================

# --- Supabase ---
# Find these in: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Google ---
# Maps JavaScript API + Places API
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# Places API server-side key (keep this secret, no NEXT_PUBLIC prefix)
GOOGLE_PLACES_API_KEY=your-google-places-server-key-here

# --- Resend ---
# Transactional email. Get your key at: resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here

# --- Cron ---
# Any random secret string — must match what Vercel sends with cron requests
# Set this in Vercel dashboard too: Settings → Environment Variables
CRON_SECRET=your_cron_secret_here

# --- Unsubscribe ---
# Random secret for signing unsubscribe tokens (HMAC-SHA256)
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=your_unsubscribe_secret_here

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
